# Telegram Bot Token — get from @BotFather
TELEGRAM_TOKEN=

# Your Telegram Chat ID — get from @userinfobot
MY_CHAT_ID=

# Absolute path to your project directory
CLAUDE_PROJECT_PATH=/Users/you/dev/your-project

# Claude model (optional, default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Auto-restart Claude Code on crash (true/false, default: true)
AUTO_RESTART=true

# Max lines to send on /status command (default: 50)
STATUS_LINES=50
