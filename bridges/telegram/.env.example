# Telegram Bot Token — get from @BotFather
TELEGRAM_TOKEN=

# Your Telegram Chat ID — get from @userinfobot
MY_CHAT_ID=

# Claude model (optional, default: claude-opus-4-6)
# Used as default when projects.json entries omit "model"
CLAUDE_MODEL=claude-opus-4-6

# Anthropic API key (optional — can use `claude login` instead)
# ANTHROPIC_API_KEY=

# Directories to scan for projects (comma-separated, default: ~/WORKSPACES)
# SCAN_ROOTS=~/WORKSPACES,~/dev,~/projects


# Max lines to send on /status command (default: 50)
STATUS_LINES=50

# Permission mode: "bypass" (default) or "interactive"
# bypass = auto-allow all tools (no prompts)
# interactive = approve/deny Write, Edit, Bash, Task from phone
# PERMISSION_MODE=bypass

# Permission timeout in milliseconds (default: 300000 = 5 min)
# Unanswered permission prompts auto-deny after this time
# PERMISSION_TIMEOUT=300000
